# Docker Compose — serves static Nuxt SPA and proxies /api to the .NET API container.
# uri strip_prefix removes /api before forwarding (API routes live at /signin, /repository, etc.).

:8080 {
	encode gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
	}

	route {
		@api path /api /api/*
		handle @api {
			uri strip_prefix /api
			reverse_proxy api-1:8080 api-2:8080
			header Cache-Control "no-store"
		}

		# Hashed build assets must not fall back to the SPA shell — during rolling
		# deploys a missing chunk would otherwise be served as text/html (200.html),
		# breaking module loading and poisoning CDN caches.
		@nuxt_assets path /_nuxt/*
		handle @nuxt_assets {
			root * /srv
			header Cache-Control "public, max-age=31536000, immutable"
			file_server
		}

		handle {
			root * /srv
			header Cache-Control "no-store"
			try_files {path} /200.html
			file_server
		}
	}
}
