  "components": {
    "schemas": {
      "AppleLoginDto": {
        "type": "object",
        "properties": {
          "identityToken": {
            "type": "string",
            "nullable": true
          },
          "authorizationCode": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateOrganizationQuery": {
        "type": "object",
        "properties": {
          "modelToCreate": {
            "$ref": "#/components/schemas/OrganizationDto"
          }
        },
        "additionalProperties": false
      },
      "CreatePublicGitSshKeyQuery": {
        "type": "object",
        "properties": {
          "modelToCreate": {
            "$ref": "#/components/schemas/PublicGitSshKeyDto"
          }
        },
        "additionalProperties": false
      },
      "CreateRepositoryMemberQuery": {
        "type": "object",
        "properties": {
          "modelToCreate": {
            "$ref": "#/components/schemas/RepositoryMemberDto"
          }
        },
        "additionalProperties": false
      },
      "CreateRepositoryRequest": {
        "type": "object",
        "properties": {
          "repositoryName": {
            "type": "string",
            "nullable": true
          },
          "isPrivate": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "GoogleLoginDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "nullable": true
          },
          "identityToken": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "HealthCheckReport": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "totalDurationMs": {
            "type": "integer",
            "format": "int64"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HealthCheckResult"
            },
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "HealthCheckResult": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "durationMs": {
            "type": "integer",
            "format": "int64"
          },
          "data": {
            "type": "object",
            "additionalProperties": { },
            "nullable": true
          },
          "exception": {
            "type": "string",
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "HealthStatus": {
        "enum": [
          "Healthy",
          "Degraded",
          "Unhealthy"
        ],
